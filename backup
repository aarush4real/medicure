    receiptFinalTotal:0,
    receiptOrderId:'',

    companies:[
      {id:'wellgo', name:'Wellgo Pharmaceuticals', sub:'Chandigarh · Est. 2005', color:'#1a6fc4'},
      {id:'pedia',  name:'PediaZone',               sub:'Panchkula · Paediatric', color:'#0d9e90'},
