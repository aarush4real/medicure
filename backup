<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Medicure By Aarush</title>
<link rel="icon" type="image/x-icon" href="https://png.pngtree.com/png-clipart/20240307/original/pngtree-medical-plus-button-symbol-png-free-download-png-image_14531815.png">
<script src="https://cdnjs.cloudflare.com/ajax/libs/alpinejs/3.13.5/cdn.min.js" defer></script>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
:root{
  --c-bg:#0b1628;
  --c-sidebar:#0d1e38;
  --c-card:#111f38;
  --c-card-hover:#152846;
  --c-border:#1e3556;
  --c-border-light:#243f63;
  --c-blue-dark:#0f2d54;
  --c-blue:#1a6fc4;
  --c-blue-mid:#2389e0;
  --c-blue-light:#4db0f7;
  --c-teal:#0d9e90;
  --c-teal-light:#14c7b8;
  --c-text:#e8f0fe;
  --c-text-muted:#7a9cc5;
  --c-text-dim:#4a6a96;
  --c-green:#22c972;
  --c-green-dim:#0f3d22;
  --c-red:#e8485a;
  --c-amber:#f5a623;
  --c-white:#ffffff;
  --gx:50%;--gy:50%;
  --shadow-card:0 4px 24px rgba(0,0,0,.45);
  --shadow-hover:0 8px 40px rgba(26,111,196,.25);
  --r:12px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  font-family:'DM Sans',sans-serif;
  background:var(--c-bg);
  color:var(--c-text);
  min-height:100vh;
  background-image:
    radial-gradient(ellipse 80% 60% at var(--gx) var(--gy), rgba(26,111,196,.18) 0%, transparent 60%),
    radial-gradient(ellipse 50% 40% at 80% 20%, rgba(13,158,144,.10) 0%, transparent 50%),
    radial-gradient(ellipse 40% 50% at 20% 80%, rgba(67,176,247,.08) 0%, transparent 50%),
    linear-gradient(135deg, #0b1628 0%, #0d1e38 50%, #091220 100%);
  background-attachment:fixed;
  transition:background-image .05s;
}
::-webkit-scrollbar{width:5px;height:5px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--c-border-light);border-radius:4px}
header{
  position:sticky;top:0;z-index:200;
  background:rgba(9,18,38,.85);
  backdrop-filter:blur(18px);
  border-bottom:1px solid var(--c-border);
  box-shadow:0 2px 30px rgba(0,0,0,.4);
}
.header-inner{
  max-width:1500px;margin:0 auto;
  display:flex;align-items:center;gap:16px;
  padding:0 24px;height:66px;
}
.logo{display:flex;align-items:center;gap:10px;text-decoration:none;flex-shrink:0}
.logo-mark{
  width:38px;height:38px;border-radius:9px;
  background:linear-gradient(135deg,var(--c-blue) 0%,var(--c-teal) 100%);
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 4px 14px rgba(26,111,196,.4);
}
.logo-mark svg{width:20px;height:20px;fill:white}
.logo-text{color:var(--c-text);font-weight:700;font-size:1.2rem;letter-spacing:-.4px}
.logo-text span{
  background:linear-gradient(90deg,var(--c-blue-light),var(--c-teal-light));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.searchbar{
  flex:1;max-width:500px;
  display:flex;align-items:center;
  background:rgba(255,255,255,.06);
  border:1px solid var(--c-border-light);
  border-radius:9px;overflow:hidden;
  transition:border-color .2s,box-shadow .2s;
}
.searchbar:focus-within{
  border-color:var(--c-blue);
  box-shadow:0 0 0 3px rgba(26,111,196,.15);
}
.searchbar input{
  flex:1;background:transparent;border:none;outline:none;
  color:var(--c-text);padding:10px 14px;font-size:.88rem;font-family:inherit;
}
.searchbar input::placeholder{color:var(--c-text-dim)}
.searchbar button{
  background:var(--c-blue);border:none;padding:10px 14px;
  color:white;cursor:pointer;transition:background .2s;
}
.searchbar button:hover{background:var(--c-blue-mid)}
.mobile-searchbar{
  display:none;
  padding:10px 12px;
  background:rgba(9,18,38,.95);
  border-bottom:1px solid var(--c-border);
}
.mobile-searchbar .searchbar{max-width:100%;flex:1;}
.hd-right{display:flex;align-items:center;gap:10px;margin-left:auto}
.badge-rx{
  background:linear-gradient(135deg,var(--c-teal),var(--c-teal-light));
  color:white;font-size:.72rem;font-weight:700;padding:5px 11px;
  border-radius:20px;letter-spacing:.4px;white-space:nowrap;
}
.cart-btn{
  position:relative;
  background:linear-gradient(135deg,var(--c-blue-dark),var(--c-blue));
  border:1px solid var(--c-blue);border-radius:9px;
  color:white;cursor:pointer;padding:9px 18px;
  display:flex;align-items:center;gap:8px;
  font-size:.88rem;font-family:inherit;font-weight:600;
  transition:all .2s;box-shadow:0 4px 14px rgba(26,111,196,.25);
}
.cart-btn:hover{
  background:linear-gradient(135deg,var(--c-blue),var(--c-blue-mid));
  box-shadow:0 6px 20px rgba(26,111,196,.4);transform:translateY(-1px);
}
.cart-badge{
  position:absolute;top:-7px;right:-7px;
  background:var(--c-red);color:white;
  font-size:.68rem;font-weight:800;
  width:19px;height:19px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  border:2px solid var(--c-bg);
}
.page-wrap{
  max-width:1500px;margin:0 auto;
  display:flex;gap:0;min-height:calc(100vh - 66px);
}
aside{
  width:268px;flex-shrink:0;
  background:rgba(13,30,56,.7);
  backdrop-filter:blur(12px);
  border-right:1px solid var(--c-border);
  padding:0 0 32px;
  position:sticky;top:66px;
  height:calc(100vh - 66px);overflow-y:auto;
}
.aside-head{
  padding:20px 20px 16px;
  border-bottom:1px solid var(--c-border);
  background:rgba(26,111,196,.06);
}
.aside-head h2{font-size:.72rem;font-weight:700;letter-spacing:1.4px;text-transform:uppercase;color:var(--c-text-dim)}
.sb-section{padding:20px 16px 8px}
.sb-label{font-size:.68rem;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:var(--c-text-dim);margin-bottom:10px;padding-left:4px}
.filter-pill{
  display:flex;align-items:center;justify-content:space-between;
  padding:8px 10px;border-radius:8px;cursor:pointer;
  transition:all .15s;margin-bottom:3px;
  border:1px solid transparent;user-select:none;
}
.filter-pill:hover{background:rgba(26,111,196,.12);border-color:rgba(26,111,196,.2)}
.filter-pill.active{
  background:rgba(26,111,196,.18);
  border-color:rgba(26,111,196,.35);
  color:var(--c-blue-light);
}
.fp-left{display:flex;align-items:center;gap:8px;font-size:.855rem}
.fp-count{
  font-size:.7rem;font-family:'DM Mono',monospace;
  background:rgba(255,255,255,.07);color:var(--c-text-muted);
  padding:2px 7px;border-radius:10px;
}
.filter-pill.active .fp-count{background:rgba(26,111,196,.25);color:var(--c-blue-light)}
.company-card{
  display:flex;align-items:center;gap:10px;
  padding:9px 10px;border-radius:9px;cursor:pointer;
  transition:all .15s;margin-bottom:5px;
  border:1.5px solid transparent;
}
.company-card:hover{background:rgba(255,255,255,.04);border-color:var(--c-border-light)}
.company-card.active{background:rgba(26,111,196,.12);border-color:var(--c-blue);}
.co-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
.co-info .co-name{font-size:.855rem;font-weight:600}
.co-info .co-sub{font-size:.68rem;color:var(--c-text-dim);margin-top:1px}
.clear-all-btn{
  width:calc(100% - 32px);margin:8px 16px 0;
  background:transparent;border:1px solid var(--c-border-light);
  color:var(--c-text-muted);padding:8px;border-radius:8px;
  cursor:pointer;font-size:.8rem;font-family:inherit;transition:all .15s;
}
.clear-all-btn:hover{border-color:var(--c-blue);color:var(--c-blue-light);background:rgba(26,111,196,.08)}
main{flex:1;padding:24px;min-width:0;overflow:hidden}
.hero{
  position:relative;overflow:hidden;
  background:linear-gradient(120deg,rgba(9,31,66,.95) 0%,rgba(15,50,90,.9) 50%,rgba(9,40,70,.95) 100%);
  border:1px solid var(--c-border-light);
  border-radius:16px;padding:28px 32px 28px;
  margin-bottom:24px;
  box-shadow:0 8px 40px rgba(0,0,0,.35);
}
.hero::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse 60% 100% at 80% 50%,rgba(26,111,196,.15) 0%,transparent 60%);
  pointer-events:none;
}
.hero-grid{display:flex;align-items:center;justify-content:space-between;gap:24px;position:relative}
.hero-text h1{
  font-size:1.55rem;font-weight:800;line-height:1.2;
  background:linear-gradient(90deg,#e8f0fe,var(--c-blue-light));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  margin-bottom:8px;
}
.hero-text p{font-size:.88rem;color:var(--c-text-muted);max-width:460px;line-height:1.55}
.hero-badges{display:flex;flex-wrap:wrap;gap:8px;margin-top:14px}
.h-badge{
  border:1px solid rgba(26,111,196,.35);
  background:rgba(26,111,196,.12);
  color:var(--c-blue-light);
  font-size:.72rem;font-weight:700;
  padding:4px 11px;border-radius:20px;letter-spacing:.3px;
}
.hero-pills{
  display:flex;flex-direction:column;gap:10px;flex-shrink:0;
  opacity:.6;font-size:3.2rem;line-height:1;
}
.topbar{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:14px;flex-wrap:wrap;gap:10px;
}
.res-info{font-size:.83rem;color:var(--c-text-muted)}
.res-info strong{color:var(--c-text);font-weight:700}
.sort-sel{
  background:rgba(255,255,255,.06);
  border:1px solid var(--c-border-light);
  border-radius:8px;padding:7px 12px;
  font-size:.83rem;color:var(--c-text);
  cursor:pointer;font-family:inherit;outline:none;transition:border-color .2s;
}
.sort-sel:focus{border-color:var(--c-blue)}
.sort-sel option{background:var(--c-card)}
.active-tags{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:14px}
.a-tag{
  background:rgba(26,111,196,.15);border:1px solid rgba(26,111,196,.3);
  color:var(--c-blue-light);font-size:.75rem;font-weight:600;
  padding:4px 10px;border-radius:20px;display:flex;align-items:center;gap:6px;
}
.a-tag button{background:none;border:none;color:inherit;cursor:pointer;font-size:1rem;line-height:1;padding:0}
.grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(218px,1fr));
  gap:16px;
}
.prod-card{
  background:var(--c-card);
  border:1px solid var(--c-border);
  border-radius:var(--r);
  display:flex;flex-direction:column;
  overflow:hidden;
  transition:transform .2s,box-shadow .25s,border-color .2s,background .2s;
  cursor:default;position:relative;
}
.prod-card::before{
  content:'';position:absolute;inset:0;border-radius:var(--r);
  background:radial-gradient(circle 200px at var(--mx,50%) var(--my,50%),
    rgba(26,111,196,.18) 0%,transparent 70%);
  opacity:0;transition:opacity .3s;pointer-events:none;z-index:0;
}
.prod-card:hover{
  transform:translateY(-4px);
  box-shadow:var(--shadow-hover),0 2px 8px rgba(0,0,0,.4);
  border-color:var(--c-blue);background:var(--c-card-hover);
}
.prod-card:hover::before{opacity:1}
.card-img{
  position:relative;padding:22px 16px 18px;
  display:flex;align-items:center;justify-content:center;
  height:115px;z-index:1;
}
.card-img.wellgo-bg{background:linear-gradient(145deg,rgba(10,30,60,.8) 0%,rgba(20,50,100,.6) 100%);}
.card-img.pedia-bg{background:linear-gradient(145deg,rgba(5,35,30,.8) 0%,rgba(10,60,50,.6) 100%);}
.med-icon{font-size:2.4rem;filter:drop-shadow(0 2px 8px rgba(0,0,0,.5))}
.cat-chip{
  position:absolute;top:8px;right:8px;
  font-size:.62rem;font-weight:800;letter-spacing:.6px;text-transform:uppercase;
  padding:3px 8px;border-radius:20px;
}
.cc-tablet  {background:rgba(109,40,217,.3);color:#c4b5fd;border:1px solid rgba(109,40,217,.4)}
.cc-capsule {background:rgba(180,83,9,.3);color:#fcd34d;border:1px solid rgba(180,83,9,.4)}
.cc-syrup   {background:rgba(6,95,70,.35);color:#6ee7b7;border:1px solid rgba(6,95,70,.5)}
.cc-drysyrup{background:rgba(124,45,18,.3);color:#fdba74;border:1px solid rgba(124,45,18,.4)}
.cc-injection{background:rgba(157,23,77,.3);color:#f9a8d4;border:1px solid rgba(157,23,77,.4)}
.cc-drop    {background:rgba(3,105,161,.3);color:#7dd3fc;border:1px solid rgba(3,105,161,.4)}
.cc-ointment{background:rgba(30,64,175,.3);color:#a5b4fc;border:1px solid rgba(30,64,175,.4)}
.brand-chip{
  position:absolute;top:8px;left:8px;
  font-size:.6rem;font-weight:800;letter-spacing:.4px;
  padding:2px 7px;border-radius:4px;
}
.bc-wellgo{background:rgba(26,111,196,.3);color:#93c5fd;border:1px solid rgba(26,111,196,.35)}
.bc-pedia {background:rgba(5,150,105,.3);color:#6ee7b7;border:1px solid rgba(5,150,105,.35)}
.card-body{padding:12px 14px 10px;flex:1;z-index:1;position:relative}
.med-name{font-size:.9rem;font-weight:700;color:var(--c-text);margin-bottom:4px;line-height:1.3}
.med-comp{font-size:.69rem;color:var(--c-text-muted);line-height:1.45;font-family:'DM Mono',monospace;margin-bottom:5px;}
.med-pack{font-size:.7rem;color:var(--c-text-dim)}
.card-foot{padding:10px 14px 14px;border-top:1px solid var(--c-border);z-index:1;position:relative;}
.price-block{margin-bottom:10px}
.price-row-1{display:flex;align-items:baseline;gap:8px;margin-bottom:3px;}
.our-price{
  font-size:1.08rem;font-weight:800;
  background:linear-gradient(90deg,var(--c-blue-light),var(--c-teal-light));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.our-label{font-size:.68rem;color:var(--c-text-dim);font-weight:500}
.mrp-row{display:flex;align-items:center;gap:6px;}
.mrp-label{font-size:.68rem;color:var(--c-text-dim)}
.mrp-val{font-size:.76rem;color:var(--c-text-dim);text-decoration:line-through;font-family:'DM Mono',monospace}
.add-btn{
  width:100%;
  background:linear-gradient(135deg,var(--c-blue-dark),var(--c-blue));
  border:1px solid var(--c-blue);border-radius:8px;color:white;
  padding:9px;font-size:.83rem;font-weight:700;
  cursor:pointer;font-family:inherit;
  display:flex;align-items:center;justify-content:center;gap:6px;
  transition:all .2s;
}
.add-btn:hover{
  background:linear-gradient(135deg,var(--c-blue),var(--c-blue-mid));
  box-shadow:0 4px 16px rgba(26,111,196,.35);transform:translateY(-1px);
}
.qty-ctrl{display:flex;align-items:center;gap:8px;justify-content:center;}
.q-btn{
  width:32px;height:32px;border-radius:8px;
  background:rgba(26,111,196,.18);border:1px solid var(--c-blue);
  color:var(--c-blue-light);font-weight:800;cursor:pointer;
  display:flex;align-items:center;justify-content:center;font-size:1rem;
  transition:background .15s;
}
.q-btn:hover{background:rgba(26,111,196,.32)}
.q-num{font-weight:800;font-size:.95rem;color:var(--c-text);min-width:28px;text-align:center}
.empty-state{text-align:center;padding:80px 20px;color:var(--c-text-muted)}
.empty-state .ei{font-size:3rem;margin-bottom:12px}
.empty-state h3{font-size:1.1rem;font-weight:700;margin-bottom:6px;color:var(--c-text)}
.cart-overlay{
  position:fixed;inset:0;z-index:300;
  background:rgba(0,0,0,.6);backdrop-filter:blur(6px);
}
.cart-drawer{
  position:absolute;right:0;top:0;bottom:0;
  width:420px;
  background:linear-gradient(180deg,#0d1f40 0%,#091525 100%);
  border-left:1px solid var(--c-border-light);
  display:flex;flex-direction:column;
  box-shadow:-8px 0 40px rgba(0,0,0,.5);
}
.cart-hd{
  padding:20px 22px;
  border-bottom:1px solid var(--c-border);
  display:flex;align-items:flex-start;justify-content:space-between;
  background:rgba(26,111,196,.06);
}
.cart-hd h2{font-size:1rem;font-weight:800}
.cart-hd-sub{font-size:.75rem;color:var(--c-green);margin-top:3px;font-weight:600}
.cart-close-btn{
  background:rgba(255,255,255,.06);border:1px solid var(--c-border-light);
  color:var(--c-text-muted);width:30px;height:30px;border-radius:7px;
  cursor:pointer;font-size:.9rem;display:flex;align-items:center;justify-content:center;
  transition:all .15s;flex-shrink:0;
}
.cart-close-btn:hover{background:rgba(232,72,90,.15);border-color:var(--c-red);color:var(--c-red)}
.cart-items{flex:1;overflow-y:auto;padding:12px 0}
.cart-empty-msg{text-align:center;padding:60px 20px;color:var(--c-text-muted)}
.cart-empty-msg .ei{font-size:2.5rem;margin-bottom:10px}
.cart-item{
  display:flex;align-items:flex-start;gap:12px;
  padding:12px 22px;border-bottom:1px solid rgba(30,53,86,.5);
}
.ci-icon{font-size:1.6rem;flex-shrink:0;padding-top:2px}
.ci-info{flex:1;min-width:0}
.ci-name{font-size:.85rem;font-weight:700;color:var(--c-text);margin-bottom:2px}
.ci-comp{font-size:.65rem;color:var(--c-text-muted);font-family:'DM Mono',monospace;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ci-co{font-size:.65rem;font-weight:700;color:var(--c-blue-light);margin-top:2px;margin-bottom:5px}
.ci-price{font-size:.85rem;font-weight:800;color:var(--c-blue-light)}
.ci-mrp-small{font-size:.67rem;color:var(--c-text-dim);text-decoration:line-through;font-family:'DM Mono',monospace}
.ci-qty{display:flex;align-items:center;gap:5px}
.cq-btn{
  width:24px;height:24px;border-radius:6px;
  background:rgba(26,111,196,.18);border:1px solid var(--c-blue);
  color:var(--c-blue-light);font-weight:800;cursor:pointer;
  display:flex;align-items:center;justify-content:center;font-size:.82rem;
  transition:background .15s;
}
.cq-btn:hover{background:rgba(26,111,196,.32)}
.cq-n{font-weight:800;font-size:.82rem;color:var(--c-text);min-width:20px;text-align:center}
.cart-foot{
  border-top:1px solid var(--c-border);
  padding:18px 22px 22px;
  background:rgba(9,18,38,.6);
}
.sum-row{
  display:flex;justify-content:space-between;
  font-size:.84rem;color:var(--c-text-muted);margin-bottom:7px;
}
.sum-row.total{
  font-size:1.08rem;font-weight:800;color:var(--c-text);
  margin-top:8px;padding-top:8px;
  border-top:1px dashed var(--c-border-light);
}
.sum-row.total span:last-child{
  background:linear-gradient(90deg,var(--c-blue-light),var(--c-teal-light));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.checkout-btn{
  width:100%;margin-top:16px;
  background:linear-gradient(135deg,var(--c-blue),var(--c-teal));
  border:none;border-radius:10px;color:white;padding:14px;
  font-size:.95rem;font-weight:800;cursor:pointer;font-family:inherit;
  transition:all .2s;box-shadow:0 4px 20px rgba(26,111,196,.3);
}
.checkout-btn:hover{transform:translateY(-2px);box-shadow:0 8px 30px rgba(26,111,196,.45);}
.checkout-btn:disabled{background:var(--c-border-light);box-shadow:none;cursor:not-allowed;transform:none;}
.receipt-overlay{
  position:fixed;inset:0;z-index:500;
  display:flex;align-items:center;justify-content:center;
  background:rgba(0,0,0,.75);backdrop-filter:blur(8px);padding:16px;
}
.receipt-box{
  width:100%;max-width:480px;max-height:90vh;overflow-y:auto;
  border-radius:20px;
  background:linear-gradient(145deg,#0d1f40 0%,#0a2a50 30%,#073a3a 70%,#071f38 100%);
  border:1px solid rgba(77,176,247,.25);
  box-shadow:0 0 0 1px rgba(20,199,184,.1),0 24px 80px rgba(0,0,0,.7),0 0 60px rgba(26,111,196,.2);
  animation:popIn .35s cubic-bezier(.34,1.56,.64,1);
}
