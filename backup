    categories:[
      {id:'tablet',    name:'Tablets',    icon:'💊'},
      {id:'capsule',   name:'Capsules',   icon:'🔵'},
      {id:'syrup',     name:'Syrup',      icon:'🍶'},
      {id:'drysyrup',  name:'Dry Syrup',  icon:'🧪'},
      {id:'injection', name:'Injections', icon:'💉'},
      {id:'drop',      name:'Drops',      icon:'💧'},
    ],

    priceRanges:[
      {id:'u50',    label:'Under ₹50',    min:0,   max:49  },
      {id:'50-99',  label:'₹50 – ₹99',   min:50,  max:99  },
      {id:'100-199',label:'₹100 – ₹199', min:100, max:199 },
      {id:'200+',   label:'₹200 & above', min:200, max:9999},
    ],

    get filtered(){
      const q = this.q.toLowerCase();
      return this.products.filter(p => {
        if(q && !p.name.toLowerCase().includes(q) && !p.comp.toLowerCase().includes(q)) return false;
        if(this.aCo && p.co !== this.aCo) return false;
        if(this.aCat && p.cat !== this.aCat) return false;
        if(this.aPr){
          const pr = this.priceRanges.find(r=>r.id===this.aPr);
          if(pr && (p.rate < pr.min || p.rate > pr.max)) return false;
        }
        return true;
      });
    },

    get sorted(){
      const arr = [...this.filtered];
      if(this.sortBy==='rate-asc')  arr.sort((a,b)=>a.rate-b.rate);
      if(this.sortBy==='rate-desc') arr.sort((a,b)=>b.rate-a.rate);
      if(this.sortBy==='name')      arr.sort((a,b)=>a.name.localeCompare(b.name));
      return arr;
    },

    get cartCount(){ return this.cart.reduce((s,i)=>s+i.qty,0) },
    get cartTotal(){ return this.cart.reduce((s,i)=>s+i.rate*i.qty,0) },
    get mrpTotal(){  return this.cart.reduce((s,i)=>s+i.mrp*i.qty,0) },

    cntByCat(catId){ return this.products.filter(p=>p.cat===catId&&(!this.aCo||p.co===this.aCo)).length },
    cntByPr(pr){ return this.products.filter(p=>p.rate>=pr.min&&p.rate<=pr.max).length },

    catLabel(cat){
      return {tablet:'Tablet',capsule:'Capsule',syrup:'Syrup',drysyrup:'Dry Syrup',injection:'Injection',drop:'Drop',ointment:'Ointment'}[cat]||cat;
    },

    getQty(id){ const i=this.cart.find(c=>c.id===id); return i?i.qty:0 },

    add(p){
      const i=this.cart.find(c=>c.id===p.id);
      if(i) i.qty++; else this.cart.push({...p,qty:1});
    },

    rem(id){
      const idx=this.cart.findIndex(c=>c.id===id);
      if(idx===-1) return;
      if(this.cart[idx].qty>1) this.cart[idx].qty--;
      else this.cart.splice(idx,1);
    },

    clearAll(){ this.q=''; this.aCo=null; this.aCat=null; this.aPr=null; },

    genOrderId(){
      const chars='ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
      let id='MC-';
      for(let i=0;i<8;i++) id+=chars[Math.floor(Math.random()*chars.length)];
      return id;
    },

    checkout(){
      if(this.cart.length===0) return;
      this.receiptItems = this.cart.map(i=>({...i}));
      this.receiptMrpTotal = Math.round(this.mrpTotal);
      this.receiptFinalTotal = Math.round(this.cartTotal);
      this.receiptOrderId = this.genOrderId();
      this.cartOpen = false;
      this.receiptOpen = true;
      this.cart = [];
    },

    closeReceipt(){
      this.receiptOpen = false;
      this.receiptItems = [];
    },

    onMouseMove(e){
      document.body.style.setProperty('--gx', (e.clientX/window.innerWidth*100).toFixed(1)+'%');
      document.body.style.setProperty('--gy', (e.clientY/window.innerHeight*100).toFixed(1)+'%');
    },

    cardMouseMove(e, el){
      const rect = el.getBoundingClientRect();
      const x = ((e.clientX-rect.left)/rect.width*50).toFixed(2)+'%';
      const y = ((e.clientY-rect.top)/rect.height*50).toFixed(2)+'%';
      el.style.setProperty('--mx',x);
      el.style.setProperty('--my',y);
    },
  };
